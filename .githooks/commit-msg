#!/usr/bin/env bash
#
# commit-msg hook — block any commit that would credit an AI assistant as a contributor.
#
msg_file="$1"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  exit 0
fi

if grep -Ei 'co-authored-by:.*(claude|anthropic)' "$msg_file" >/dev/null 2>&1; then
  echo "" >&2
  echo "ERROR: commit message contains an AI assistant 'Co-Authored-By' trailer." >&2
  echo "       Refusing to commit. Remove the trailer so the AI assistant is not listed" >&2
  echo "       as a contributor." >&2
  echo "" >&2
  exit 1
fi

exit 0